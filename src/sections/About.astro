---
// About-F: Image Right + Floating Pill - Design moderno com asimetria
interface Stat { value: string; label: string; }
interface Props {
  title: string;
  desc: string;
  image: string;
  btnText: string;
  btnLink: string;
  stats: Stat[];
}
const { title, desc, image, btnText, btnLink, stats } = Astro.props;
---
<section class="py-24 bg-white relative">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      
      <!-- Texto Esquerda -->
      <div class="order-2 lg:order-1">
        <h2 class="text-4xl md:text-5xl font-black text-dark tracking-tighter mb-8 leading-tight">
          {title}
        </h2>
        <p class="text-lg text-gray-500 leading-relaxed mb-10 font-medium">
          {desc}
        </p>

        <!-- Feature List from Stats -->
        <div class="space-y-6 mb-12">
          {stats.slice(1, 4).map((stat) => (
            <div class="flex items-center gap-4 group">
              <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all transform group-hover:rotate-12">
                 <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div class="text-sm font-black text-dark uppercase tracking-widest">{stat.label}: <span class="text-primary">{stat.value}</span></div>
            </div>
          ))}
        </div>

        <a href={btnLink} class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-white font-black rounded-2xl hover:shadow-2xl hover:shadow-primary/30 transition-all uppercase tracking-widest text-[10px]">
          {btnText}
           <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <!-- Imagem Direita with Pills -->
      <div class="order-1 lg:order-2 relative group">
        <div class="relative rounded-[2.5rem] lg:rounded-[4rem] overflow-hidden shadow-2xl">
          <img src={image} class="w-full h-[500px] object-cover transition-transform duration-700 group-hover:scale-110" alt="About detail" />
          <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 via-transparent to-transparent"></div>
        </div>
        
        <!-- Floating Pills -->
        <div class="absolute -top-6 -left-6 bg-white rounded-2xl p-6 shadow-2xl border border-gray-100 animate-bounce-subtle">
           <div class="text-3xl font-black text-primary mb-1">{stats[0]?.value}</div>
           <div class="text-[10px] font-black text-gray-400 uppercase tracking-widest leading-none">{stats[0]?.label}</div>
        </div>
        
        <div class="absolute -bottom-6 -right-6 bg-dark text-white rounded-2xl px-6 py-4 shadow-2xl">
           <div class="flex items-center gap-3">
              <div class="flex -space-x-3">
                {[1,2,3].map(i => <div class={`w-8 h-8 rounded-full border-2 border-dark bg-gray-700 overflow-hidden shadow-lg shadow-black/20`} />)}
              </div>
              <div class="text-[9px] font-bold uppercase tracking-widest">Equipe<br/>Qualificada</div>
           </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .animate-bounce-subtle {
    animation: bounce-subtle 4s ease-in-out infinite;
  }
</style>